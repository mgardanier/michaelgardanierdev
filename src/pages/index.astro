---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Michael Gardanier" description="Personal website and portfolio of Michael Gardanier">
  <section class="hero">
    <h1>Hi, I'm Michael Gardanier</h1>
  </section>

  <section id="about" class="section">
    <div class="profile-image">
      <img src="/assets/images/profile_image.jpg" alt="Profile Picture of Michael Gardanier" />
    </div>
    <div class="social-links-profile">
      <a href="https://www.linkedin.com/in/michael-gardanier-056635b6/" target="_blank" rel="noopener noreferrer" title="LinkedIn">
        <i class="fab fa-linkedin"></i>
      </a>
      <a href="https://github.com/mgardanier" target="_blank" rel="noopener noreferrer" title="GitHub">
        <i class="fab fa-github"></i>
      </a>
    </div>
    <h2>About Me</h2>
    <p>
      I'm a software engineer with over 6 years of experience in full stack development. I love working on
      solving tough problems and learning new things.
    </p>
    <p>When I'm not working, I love preteneding to be a woodworker and building FPV drones.</p>
  </section>
</BaseLayout>
